<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:bal="http://wixtoolset.org/schemas/v4/wxs/bal"
     xmlns:netfx="http://wixtoolset.org/schemas/v4/wxs/netfx">

    <Bundle
        Name="winAlert"
        Version="$(var.Version)"
        Manufacturer="$(var.Manufacturer)"
        UpgradeCode="$(var.BundleUpgradeCode)"
        Version="@(Version)"
        Compressed="yes"
        InstallerVersion="500"
        AboutUrl="https://github.com/$(var.GitHubOrg)/$(var.GitHubRepo)"
        IconSourceFile="$(var.IconPath)"
        BundleCopyright="Copyright (c) 2026 $(var.Manufacturer)">

        <Variable Name="InstallFolder" Value="[LocalAppDataFolder]winAlert" />

        <!-- Bootstrap Application UI -->
        <bal:BootstrapperApplication
            Id="WixStandardBootstrapperApplication.RtfLargeLicense"
            LicenseFile=""
            ShowFilesInUse="yes"
            ShowVersion="yes"
            Theme="rtfLarge" />

        <!-- Chains: ExePackage for .NET runtime, MsiPackage for app -->
        <Chain>
            <!-- Note: .NET 8 runtime is embedded in the self-contained publish -->
            <!-- No separate runtime installer needed when self-contained -->

            <MsiPackage
                Id="winAlertMsi"
                SourceFile="$(var.MsiPath)"
                DownloadUrl="https://github.com/$(var.GitHubOrg)/$(var.GitHubRepo)/releases/download/v$(var.Version)/winAlert-$(var.Version)-setup.exe"
                DetectCondition="NOT Installed"
                InstallCondition="NOT Installed"
                After="bundleDetect"
                DisplayInternalUI="yes">
                <MsiProperty Name="INSTALLFOLDER" Value="[InstallFolder]" />
            </MsiPackage>
        </Chain>
    </Bundle>
</Wix>
