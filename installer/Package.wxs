<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
    <Package
        Name="winAlert"
        Version="1.0.0"
        Manufacturer="winAlert"
        UpgradeCode="12345678-1234-1234-1234-123456789012"
        Scope="perUser"
        Compressed="yes"
        InstallerVersion="500">

        <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
        <MediaTemplate EmbedCab="yes" />

        <Feature Id="ProductFeature" Title="winAlert" Level="1">
            <ComponentRef Id="MainExecutable" />
            <ComponentRef Id="ApplicationShortcut" />
            <ComponentRef Id="ApplicationShortcutDesktop" />
        </Feature>

        <StandardDirectory Id="LocalAppDataFolder">
            <Directory Id="INSTALLFOLDER" Name="winAlert">
                <Component Id="MainExecutable" Guid="A1B2C3D4-E5F6-7890-ABCD-EF1234567890" KeyPath="yes">
                    <File Id="WinAlertExe" Source="C:\Users\mubdiur\Documents\GitHub\winAlert\publish\winAlert.exe" />
                </Component>
            </Directory>
        </StandardDirectory>

        <StandardDirectory Id="DesktopFolder">
            <Component Id="ApplicationShortcutDesktop" Guid="B2C3D4E5-F6A7-8901-BCDE-F23456789012" KeyPath="yes">
                <Shortcut
                    Id="DesktopShortcut"
                    Name="winAlert"
                    Description="Enterprise Alert Monitor"
                    Target="[INSTALLFOLDER]winAlert.exe"
                    WorkingDirectory="INSTALLFOLDER" />
                <RemoveFolder Id="RemoveDesktopFolder" On="uninstall" />
            </Component>
        </StandardDirectory>

        <StandardDirectory Id="StartMenuFolder">
            <Directory Id="ApplicationProgramsFolder" Name="winAlert">
                <Component Id="ApplicationShortcut" Guid="C3D4E5F6-A7B8-9012-CDEF-345678901234" KeyPath="yes">
                    <Shortcut
                        Id="ApplicationStartMenuShortcut"
                        Name="winAlert"
                        Description="Enterprise Alert Monitor"
                        Target="[INSTALLFOLDER]winAlert.exe"
                        WorkingDirectory="INSTALLFOLDER" />
                    <RemoveFolder Id="RemoveApplicationProgramsFolder" On="uninstall" />
                </Component>
            </Directory>
        </StandardDirectory>

        <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER" />
    </Package>
</Wix>
