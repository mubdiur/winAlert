<UserControl x:Class="winAlert.Controls.StatusIndicator"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:winAlert.Converters">

    <UserControl.Resources>
        <converters:ConnectionStatusToColorConverter x:Key="ConnectionStatusToColorConverter"/>
    </UserControl.Resources>

    <Grid Width="24" Height="24">
        <Ellipse x:Name="StatusDot"
                 Width="12"
                 Height="12"
                 Fill="{Binding IsListening, Converter={StaticResource ConnectionStatusToColorConverter}}"
                 VerticalAlignment="Center"
                 HorizontalAlignment="Center">
            <Ellipse.Style>
                <Style TargetType="Ellipse">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsListening}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                       From="1.0" To="0.5"
                                                       Duration="0:0:1"
                                                       AutoReverse="True"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Ellipse.Style>
        </Ellipse>

        <!-- Glow effect when listening -->
        <Ellipse x:Name="GlowRing"
                 Width="20"
                 Height="20"
                 Fill="Transparent"
                 Stroke="{Binding IsListening, Converter={StaticResource ConnectionStatusToColorConverter}}"
                 StrokeThickness="2"
                 Opacity="0.3"
                 VerticalAlignment="Center"
                 HorizontalAlignment="Center">
            <Ellipse.Style>
                <Style TargetType="Ellipse">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsListening}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                       From="0.5" To="0"
                                                       Duration="0:0:1.5"/>
                                        <DoubleAnimation Storyboard.TargetProperty="Width"
                                                       From="12" To="24"
                                                       Duration="0:0:1.5"/>
                                        <DoubleAnimation Storyboard.TargetProperty="Height"
                                                       From="12" To="24"
                                                       Duration="0:0:1.5"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Ellipse.Style>
        </Ellipse>
    </Grid>

</UserControl>
