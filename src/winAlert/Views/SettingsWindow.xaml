<Window x:Class="winAlert.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Settings"
        Height="550"
        Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}"
        FontFamily="{DynamicResource MaterialDesignFont}"
        TextElement.Foreground="{DynamicResource TextPrimaryBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="Settings"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="0,0,0,24"/>

        <!-- Settings Sections -->
        <ScrollViewer Grid.Row="1" 
                      Style="{StaticResource MaterialDesignScrollViewer}"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Network Settings -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16"
                        Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Network"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,12"/>

                        <TextBlock Text="Listen Port"
                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                   FontSize="12"
                                   Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Port}"
                                 Style="{StaticResource MaterialDesignTextBox}"
                                 Width="100"
                                 HorizontalAlignment="Left"
                                 Padding="12,8"
                                 Background="{DynamicResource SurfaceVariantBrush}"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Audio Settings -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16"
                        Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Audio"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Enable Audio Notifications"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="13"
                                       VerticalAlignment="Center"/>
                            <ToggleButton Grid.Column="1"
                                          Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                          IsChecked="{Binding AudioEnabled}"/>
                        </Grid>

                        <TextBlock Text="Master Volume"
                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                   FontSize="12"
                                   Margin="0,0,0,4"/>
                        <Slider Value="{Binding MasterVolume}"
                                Minimum="0"
                                Maximum="1"
                                TickFrequency="0.1"
                                IsSnapToTickEnabled="True"
                                Width="200"
                                HorizontalAlignment="Left"
                                Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Notification Settings -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16"
                        Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Notifications"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Show Overlay for Critical"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="13"
                                       VerticalAlignment="Center"/>
                            <ToggleButton Grid.Column="1"
                                          Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                          IsChecked="{Binding ShowOverlayForCritical}"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Flash Taskbar"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="13"
                                       VerticalAlignment="Center"/>
                            <ToggleButton Grid.Column="1"
                                          Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                          IsChecked="{Binding FlashTaskbar}"/>
                        </Grid>

                        <TextBlock Text="Seconds Before Alarm"
                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                   FontSize="12"
                                   Margin="0,16,0,4"/>
                        <StackPanel Orientation="Horizontal">
                            <Slider Value="{Binding SirenDelaySeconds}"
                                    Minimum="5"
                                    Maximum="120"
                                    TickFrequency="5"
                                    IsSnapToTickEnabled="True"
                                    Width="200"
                                    VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding SirenDelaySeconds, StringFormat='{}{0} sec'}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="13"
                                       VerticalAlignment="Center"
                                       Margin="12,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Behavior Settings -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel>
                        <TextBlock Text="Behavior"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Minimize to Tray"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="13"
                                       VerticalAlignment="Center"/>
                            <ToggleButton Grid.Column="1"
                                          Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                          IsChecked="{Binding MinimizeToTray}"/>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Start Minimized"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="13"
                                       VerticalAlignment="Center"/>
                            <ToggleButton Grid.Column="1"
                                          Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                          IsChecked="{Binding StartMinimized}"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Always on Top"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="13"
                                       VerticalAlignment="Center"/>
                            <ToggleButton Grid.Column="1"
                                          Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                          IsChecked="{Binding AlwaysOnTop}"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,24,0,0">
            <Button Content="Reset Defaults"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Command="{Binding ResetCommand}"
                    Margin="0,0,8,0"
                    Padding="16,8"/>
            <Button Content="Cancel"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Command="{Binding CancelCommand}"
                    Margin="0,0,8,0"
                    Padding="16,8"/>
            <Button Content="Save"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Command="{Binding SaveCommand}"
                    Padding="24,8"/>
        </StackPanel>
    </Grid>

</Window>